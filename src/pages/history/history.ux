<!-- 淬火工坊 | 作者：弦 | 抖音：LOVE54760 | B站：北极弦 -->
<template>
  <div class="history-page">
    <!-- 标题 -->
    <div class="header">
      <text class="header-title">锻造记录</text>
      <div class="header-line"></div>
    </div>

    <!-- 可滚动记录列表 -->
    <div class="list-area" if="{{ hasRecords }}">
      <!-- 统计入口卡片 -->
      <div class="stats-entry" onclick="viewStats">
        <text class="stats-icon">[+]</text>
        <text class="stats-text">查看周报/月报统计</text>
        <text class="stats-arrow">></text>
      </div>

      <div class="record-card" for="{{ records }}">
        <div class="card-main" onclick="viewDetail($idx)">
          <div class="card-left">
            <text class="record-badge" style="color: {{ $item.badgeColor }}">{{ $item.badgeTier }}</text>
          </div>
          <div class="card-right">
            <text class="record-date">{{ $item.dateShort }}</text>
            <div class="card-row-bottom">
              <text class="record-stat">{{ $item.strokes }} 次</text>
              <text class="record-stat-sub">{{ $item.durationText }}</text>
            </div>
          </div>
        </div>
        <div class="btn-del" onclick="deleteItem($idx)">
          <text class="btn-del-icon">×</text>
        </div>
      </div>
    </div>

    <!-- 空状态 -->
    <div class="empty-area" if="{{ !hasRecords }}">
      <!-- 统计入口卡片（空状态也显示） -->
      <div class="stats-entry" onclick="viewStats">
        <text class="stats-icon">[+]</text>
        <text class="stats-text">查看周报/月报统计</text>
        <text class="stats-arrow">></text>
      </div>
      <text class="empty-text">暂无记录</text>
    </div>

    <!-- 底部操作 -->
    <div class="bottom-area">
      <div class="btn-back" onclick="goBack">
        <text class="btn-text">返回</text>
      </div>
      <div class="btn-clear" onclick="showClearConfirm" if="{{ hasRecords }}">
        <text class="btn-text-danger">清空全部</text>
      </div>
    </div>
    <div class="safe-bottom"></div>

    <!-- 清空确认弹窗 -->
    <div class="modal-overlay" if="{{ showConfirm }}">
      <div class="modal-box">
        <text class="modal-title">警告</text>
        <text class="modal-desc">确认删除所有记录？</text>
        <div class="modal-actions">
          <div class="modal-btn-cancel" onclick="cancelClear">
            <text class="modal-btn-text">取消</text>
          </div>
          <div class="modal-btn-confirm" onclick="confirmClear">
            <text class="modal-btn-confirm-text">删除</text>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import router from "@system.router"
import storage from "@system.storage"
import { loadHistory, deleteRecord, clearHistory, formatDuration } from "../../common/utils.js"

export default {
  private: {
    records: [],
    hasRecords: false,
    showConfirm: false
  },

  onShow() {
    this._loadRecords()
  },

  _loadRecords() {
    var self = this
    loadHistory(storage, function (history) {
      for (var i = 0; i < history.length; i++) {
        history[i].durationText = formatDuration(history[i].duration || 0)
        var d = history[i].date || ''
        history[i].dateShort = d.length > 10 ? d.substring(5) : d
        if (history[i].ratings && history[i].ratings.overall) {
          history[i].badgeTier = history[i].ratings.overall.tier
          history[i].badgeColor = history[i].ratings.overall.color
        } else if (history[i].rating) {
          history[i].badgeTier = history[i].rating.tier
          history[i].badgeColor = history[i].rating.color
        } else {
          history[i].badgeTier = '-'
          history[i].badgeColor = '#666666'
        }
      }
      self.records = history
      self.hasRecords = history.length > 0
    })
  },

  viewDetail(index) {
    if (this.records[index]) {
      router.push({
        uri: "/pages/report",
        params: {
          sessionData: JSON.stringify(this.records[index])
        }
      })
    }
  },

  deleteItem(index) {
    var self = this
    deleteRecord(storage, index, function (success) {
      if (success) {
        self._loadRecords()
      }
    })
  },

  goBack() {
    router.back()
  },

  showClearConfirm() {
    this.showConfirm = true
  },

  cancelClear() {
    this.showConfirm = false
  },

  confirmClear() {
    var self = this
    clearHistory(storage, function (success) {
      if (success) {
        self.showConfirm = false
        self._loadRecords()
      }
    })
  },

  viewStats() {
    router.push({
      uri: "/pages/stats"
    })
  }
}
</script>

<style>
