  padding-top: 8px;
  padding-bottom: 8px;
  padding-left: 10px;
}

.card-left {
  width: 40px;
  justify-content: center;
  align-items: center;
  border-right-width: 1px;
  border-right-color: #333333;
  margin-right: 10px;
}

.record-badge {
  font-size: 26px;
  font-weight: bold;
}

