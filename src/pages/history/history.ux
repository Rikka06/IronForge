}

.btn-clear {
  width: 100px;
  height: 36px;
  border-radius: 18px;
  border-width: 1px;
  border-color: #FF3333;
  justify-content: center;
  align-items: center;
}

.btn-text-danger {
  font-size: 14px;
  color: #FF3333;
