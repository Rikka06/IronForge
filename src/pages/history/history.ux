  font-size: 20px;
  color: #FFFFFF;
  font-weight: bold;
  letter-spacing: 2px;
}

/* 统计入口卡片样式 */
.stats-entry {
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 44px;
  background-color: #1A1A1A;
  border-radius: 22px;
  margin-bottom: 10px;
  border-width: 1px;
  border-color: #333333;
}

.stats-icon {
  font-size: 16px;
  margin-right: 8px;
}

.stats-text {
  font-size: 14px;
  color: #FFD700;
  font-weight: bold;
}

.stats-arrow {
  font-size: 14px;
  color: #666666;
  margin-left: 8px;
}

.header-line {
  width: 40px;
  height: 2px;
  background-color: #FF4500;
  margin-top: 4px;
}

/* 列表区域：flex:1 占满剩余空间，overflow:scroll 可滚动 */
.list-area {
  flex-direction: column;
  width: 92%;
  flex: 1;
  overflow: scroll;
}

/* 每条记录：card-main（可点击跳转）+ btn-del（独立删除） */
.record-card {
  flex-direction: row;
  align-items: center;
  background-color: #111111;
  border-radius: 8px;
  margin-bottom: 7px;
  border-width: 1px;
  border-color: #222222;
}

/* 可点击区域（跳转详情） */
.card-main {
  flex: 1;
  flex-direction: row;
