  flex-direction: column;
  align-items: center;
  background-color: #000000;
  width: 100%;
  height: 100%;
  padding-top: 10px;
  padding-bottom: 8px;
}

.header {
  flex-direction: column;
  align-items: center;
  margin-bottom: 8px;
  width: 100%;
}

.header-row {
  flex-direction: row;
  justify-content: center;
  align-items: center;
  width: 100%;
  position: relative;
}

